# ============================================================
# .env.example  —  copy to .env and fill in values
# .env is gitignored — never commit real secrets
# ============================================================

COMPOSE_PROJECT_NAME=mcp-stack

# ---- ha-mcp ------------------------------------------------
HOMEASSISTANT_URL=https://ha.espinosahome.com
HOMEASSISTANT_TOKEN=your-long-lived-access-token-here

# ---- m365-mcp ----------------------------------------------
# No secrets here — auth handled by: docker exec -it m365-mcp m365 login
# and persisted in the m365-auth Docker volume.

# ---- flaresolverr --------------------------------------------
# HTTP proxy to bypass Cloudflare anti-bot (port 8191)
# Defaults shown — override only if needed
# FLARESOLVERR_LOG_LEVEL=info
# FLARESOLVERR_LOG_HTML=false
# FLARESOLVERR_CAPTCHA_SOLVER=none

# ---- square-mcp -----------------------------------------------
# No secrets — auth handled interactively via SMS OTP.
# Session persisted in square-session Docker volume.
# Favorites config: services/square-mcp/config/favorites.json

# ---- postgres ------------------------------------------------
POSTGRES_USER=mcp
POSTGRES_PASSWORD=your-postgres-password-here
POSTGRES_DB=mcp

# ---- opalstack ----------------------------------------------
# HTTP transport — no container needed, configured directly in Claude Desktop/Code
# URL: https://my.opalstack.com/mcp
# Token: stored in .env on each client machine, not deployed to LXC
