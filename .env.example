# ============================================================
# .env.example  —  copy to .env and fill in values
# .env is gitignored — never commit real secrets
# ============================================================

COMPOSE_PROJECT_NAME=mcp-stack

# ---- ha-mcp ------------------------------------------------
HOMEASSISTANT_URL=https://ha.espinosahome.com
HOMEASSISTANT_TOKEN=your-long-lived-access-token-here

# ---- m365-mcp ----------------------------------------------
# No secrets here — auth handled by: docker exec -it m365-mcp m365 login
# and persisted in the m365-auth Docker volume.

# ---- opalstack ----------------------------------------------
# HTTP transport — no container needed, configured directly in Claude Desktop/Code
# URL: https://my.opalstack.com/mcp
# Token: stored in .env on each client machine, not deployed to LXC
