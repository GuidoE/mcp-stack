# ============================================================
# .env.example  —  copy to .env and fill in values
# .env is gitignored — never commit real secrets
# ============================================================

# ---- General -----------------------------------------------
COMPOSE_PROJECT_NAME=mcp-stack

# ---- m365-mcp ----------------------------------------------
# No secrets needed here — auth is handled by:
#   docker exec -it m365-mcp m365 login
# and persisted in the m365-auth Docker volume.
# The volume survives container restarts and rebuilds.

# ---- Future services ---------------------------------------
# Add service-specific env vars here as you expand the stack
# SOME_API_KEY=
